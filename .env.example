# Heaven Ladder 部署配置
# 复制为 .env 后填写: cp .env.example .env
# 行内注释请保留 # 前空格，或单独成行（供 load_env 解析）

# ── 主控节点 ──
MASTER_IP=                       # 主控 VPS 公网 IPv4（Hosts/订阅前缀会用到）
PANEL_PORT=8000                  # Marzban 本机端口（仅 127.0.0.1，勿对公网开放）
PANEL_PROXY_PORT=8080            # Nginx 公网反代端口（面板+订阅）
PANEL_PUBLIC_ACCESS=true         # true: UFW 放行 PANEL_PROXY_PORT；false: 仅用 SSH 隧道
ADMIN_WHITELIST_IP=              # 可选：仅 IPv4 家宽白名单（与公网 8080 二选一即可）

# ── REALITY 伪装目标（选高信誉站点）──
REALITY_DEST=www.microsoft.com:443
REALITY_SERVER_NAME=www.microsoft.com

# ── 节点区域标签（用于客户端分组）──
NODE1_NAME=sg-primary
NODE1_REGION=新加坡
NODE1_IP=

NODE2_NAME=jp-backup
NODE2_REGION=日本
NODE2_IP=

NODE3_NAME=us-fallback
NODE3_REGION=美国
NODE3_IP=

# ── Hysteria2 备用（可选）──
HY2_PORT=8443
HY2_PASSWORD=                    # openssl rand -base64 32

# ── 监控（可选）──
UPTIME_KUMA_PORT=3001
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
