# Heaven Ladder 部署配置
# 复制为 .env 后填写: cp .env.example .env

# ── 主控节点 ──
MASTER_IP=                       # 主控 VPS 公网 IP
PANEL_PORT=8000                  # Marzban 面板端口
ADMIN_WHITELIST_IP=              # 你的家庭公网 IP（面板仅允许此 IP 访问）

# ── REALITY 伪装目标（选高信誉站点）──
REALITY_DEST=www.microsoft.com:443
REALITY_SERVER_NAME=www.microsoft.com

# ── 节点区域标签（用于客户端分组）──
NODE1_NAME=sg-primary
NODE1_REGION=新加坡
NODE1_IP=

NODE2_NAME=jp-backup
NODE2_REGION=日本
NODE2_IP=

NODE3_NAME=us-fallback
NODE3_REGION=美国
NODE3_IP=

# ── Hysteria2 备用（可选）──
HY2_PORT=8443
HY2_PASSWORD=                    # openssl rand -base64 32

# ── 监控（可选）──
UPTIME_KUMA_PORT=3001
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
